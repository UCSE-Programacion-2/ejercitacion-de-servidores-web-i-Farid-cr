{
  "env": {
    "node": true,
    "es2021": true,
    "jest": true
  },
  "extends": [
    "airbnb-base",
    "prettier"
  ],
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "script"
  },
  "rules": {
    "no-console": "off"
  },
  "overrides": [
    {
      "files": ["tests/**/*.js", "**/*.test.js"],
      "rules": {
        "prefer-arrow-callback": "off",
        "func-names": "off",
        "import/no-extraneous-dependencies": "off"
      }
    },
    {
      "files": ["src/server.js"],
      "rules": {
        "no-unused-vars": "off"
      }
    }
  ],
  "ignorePatterns": ["Configuration-Files/"]
}
